<UserControl x:Class="projekt2wpf.StatisticsBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Height="26" Background="#F2F2F2"
            BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
        <Grid Margin="10,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding BookCount, StringFormat='Books: {0}'}"
                           FontSize="11" Margin="0,0,10,0"/>
                <TextBlock Text="|" Foreground="#CCCCCC" FontSize="11" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding ReadCount, StringFormat='Read: {0}'}"
                           FontSize="11" Margin="0,0,10,0"/>
                <TextBlock Text="|" Foreground="#CCCCCC" FontSize="11" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding ReadingCount, StringFormat='Reading: {0}'}"
                           FontSize="11" Margin="0,0,10,0"/>
                <TextBlock Text="|" Foreground="#CCCCCC" FontSize="11" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding AvgRating, StringFormat='Avg rating: {0}'}"
                           FontSize="11" Margin="0,0,10,0"/>
                <TextBlock Text="|" Foreground="#CCCCCC" FontSize="11" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding TopGenre, StringFormat='Top genre: {0}'}"
                           FontSize="11"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       FontSize="11" Foreground="#777777"/>
        </Grid>
    </Border>
</UserControl>
