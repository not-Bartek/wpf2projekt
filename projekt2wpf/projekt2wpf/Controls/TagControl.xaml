<UserControl x:Class="projekt2wpf.TagControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:projekt2wpf">

    <ItemsControl ItemsSource="{Binding Tags,
                      RelativeSource={RelativeSource AncestorType=local:TagControl}}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Background="{StaticResource PrimaryBrush}"
                        CornerRadius="12" Margin="3,3,0,0" Padding="9,4">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding}"
                                   Foreground="White" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <Button Content="×"
                                FontSize="13" Width="18" Height="18"
                                Padding="0" Margin="6,0,0,0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="White" Cursor="Hand"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsEditable,
                                    RelativeSource={RelativeSource AncestorType=local:TagControl},
                                    Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding RemoveTagCommand,
                                    RelativeSource={RelativeSource AncestorType=local:TagControl}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
