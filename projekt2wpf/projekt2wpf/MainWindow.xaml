<Window x:Class="projekt2wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:projekt2wpf"
        Title="Libraria"
        Width="1000" Height="650"
        MinWidth="920" MinHeight="500">

    <Window.Resources>
        <local:ByteToImageConverter x:Key="ByteToImageConverter"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteBookCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <Menu DockPanel.Dock="Top" Background="White" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <MenuItem Header="Repository"/>
            <MenuItem Header="Book">
                <MenuItem Header="Add..."    Command="{Binding AddBookCommand}"    InputGestureText="Ctrl+N"/>
                <MenuItem Header="Edit..."/>
                <MenuItem Header="Delete..." Command="{Binding DeleteBookCommand}" InputGestureText="Del"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top" Height="64" Background="{StaticResource PrimaryBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="📚" FontSize="28" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Libraria"
                               FontFamily="Segoe Script" FontSize="22"
                               Foreground="White"/>
                    <TextBlock Text="Personal Book Manager"
                               FontSize="11" Foreground="#AAB4C8"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Height="24"
                Background="#F2F2F2" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <Grid Margin="10,0">
                <TextBlock Text="{Binding BookCount, StringFormat='Books: {0}'}"
                           VerticalAlignment="Center" FontSize="11"/>
                <TextBlock Text="{Binding StatusMessage}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="11" Foreground="#777777"/>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#FAFAFA">
            <ListBox ItemsSource="{Binding Books}"
                     SelectedItem="{Binding SelectedBook}"
                     Background="Transparent" BorderThickness="0"
                     Padding="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="140" Margin="6" Cursor="Hand">
                            <Border Width="120" Height="160"
                                    Background="#E4E4E4"
                                    HorizontalAlignment="Center"
                                    CornerRadius="4" ClipToBounds="True">
                                <Grid>
                                    <TextBlock Text="No Cover"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#999999" FontSize="12"/>
                                    <Image Source="{Binding CoverImage, Converter={StaticResource ByteToImageConverter}}"
                                           Stretch="UniformToFill"/>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="SemiBold" TextWrapping="Wrap"
                                       Margin="0,6,0,2" FontSize="12"
                                       TextAlignment="Center"/>
                            <TextBlock Text="{Binding Author}"
                                       Foreground="#888888" TextWrapping="Wrap"
                                       FontSize="11" TextAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin"  Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="RootBorder"
                                            BorderThickness="2"
                                            BorderBrush="Transparent"
                                            CornerRadius="6"
                                            Background="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="RootBorder" Property="BorderBrush"
                                                    Value="{StaticResource AccentBrush}"/>
                                            <Setter TargetName="RootBorder" Property="Background"
                                                    Value="#18E94560"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected"  Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="RootBorder" Property="Background"
                                                    Value="#09000000"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

            </ListBox>
        </ScrollViewer>

    </DockPanel>
</Window>
