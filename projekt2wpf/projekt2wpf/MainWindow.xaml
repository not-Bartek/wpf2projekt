<Window x:Class="projekt2wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:projekt2wpf"
        Title="Libraria"
        Width="1000" Height="650"
        MinWidth="920" MinHeight="500">

    <Window.Resources>
        <DataTemplate DataType="{x:Type local:WelcomeViewModel}">
            <local:WelcomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:BookListViewModel}">
            <local:BookListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:BookDetailViewModel}">
            <local:BookDetailView/>
        </DataTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Delete"               Command="{Binding BookDeleteCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="N"   Command="{Binding BookAddCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="E"   Command="{Binding BookEditCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <Menu DockPanel.Dock="Top" Background="White" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <MenuItem Header="Repository">
                <MenuItem Header="Create..." Command="{Binding RepositoryCreateCommand}"/>
                <MenuItem Header="Open..."   Command="{Binding RepositoryOpenCommand}"/>
            </MenuItem>
            <MenuItem Header="Book">
                <MenuItem Header="Add..."    Command="{Binding BookAddCommand}"    InputGestureText="Ctrl+N"/>
                <MenuItem Header="Edit..."   Command="{Binding BookEditCommand}"   InputGestureText="Ctrl+E"/>
                <MenuItem Header="Delete..." Command="{Binding BookDeleteCommand}" InputGestureText="Del"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top" Height="64" Background="{StaticResource PrimaryBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="📚" FontSize="28" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Libraria"
                               FontFamily="Segoe Script" FontSize="22" Foreground="White"/>
                    <TextBlock Text="Personal Book Manager"
                               FontSize="11" Foreground="#AAB4C8"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <local:StatisticsBarControl DockPanel.Dock="Bottom"/>

        <ContentControl Content="{Binding CurrentPage}" Focusable="False"/>

    </DockPanel>
</Window>
