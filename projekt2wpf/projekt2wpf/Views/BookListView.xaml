<UserControl x:Class="projekt2wpf.BookListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:projekt2wpf">

    <UserControl.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteBookCommand}"/>
    </UserControl.InputBindings>

    <DockPanel Background="#FAFAFA">

        <Border DockPanel.Dock="Top"
                Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="12,8">
            <WrapPanel Orientation="Horizontal">

                <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                         Width="200" Height="28" VerticalContentAlignment="Center"
                         Padding="6,0" Margin="0,0,8,0"
                         Tag="🔍 Search title or author..."/>

                <ComboBox ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding StatusFilter}"
                          Width="100" Height="28" Margin="0,0,8,0"
                          VerticalContentAlignment="Center"/>

                <ComboBox ItemsSource="{Binding RatingOptions}"
                          SelectedItem="{Binding RatingFilter}"
                          Width="70" Height="28" Margin="0,0,8,0"
                          VerticalContentAlignment="Center"/>

                <ComboBox ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SortBy}"
                          Width="90" Height="28" Margin="0,0,8,0"
                          VerticalContentAlignment="Center"/>

                <Button Content="✕ Clear"
                        Command="{Binding ClearFiltersCommand}"
                        Height="28" Padding="10,0"
                        Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="#F5F5F5" BorderBrush="#CCCCCC"
                        Cursor="Hand"/>

            </WrapPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ListBox ItemsSource="{Binding FilteredBooks}"
                     SelectedItem="{Binding SelectedBook}"
                     Background="Transparent" BorderThickness="0"
                     Padding="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.OpenDetailCommand,
                                          RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}"
                                Background="Transparent" BorderThickness="0"
                                Padding="0" Cursor="Hand">
                            <StackPanel Width="140" Margin="6">
                                <Border Width="120" Height="160"
                                        Background="#E4E4E4"
                                        HorizontalAlignment="Center"
                                        CornerRadius="4" ClipToBounds="True">
                                    <Grid>
                                        <TextBlock Text="No Cover"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#999999" FontSize="12"/>
                                        <Image Source="{Binding CoverImage, Converter={StaticResource ByteToImageConverter}}"
                                               Stretch="UniformToFill"/>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold" TextWrapping="Wrap"
                                           Margin="0,6,0,2" FontSize="12"
                                           TextAlignment="Center"/>
                                <TextBlock Text="{Binding Author}"
                                           Foreground="#888888" TextWrapping="Wrap"
                                           FontSize="11" TextAlignment="Center"/>
                                <local:RatingControl Value="{Binding Rating, TargetNullValue=0}"
                                                     IsReadOnly="True" StarSize="12"
                                                     HorizontalAlignment="Center"
                                                     Margin="0,3,0,0"
                                                     Visibility="{Binding Rating, Converter={StaticResource NullToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin"  Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Root"
                                            BorderThickness="2"
                                            BorderBrush="Transparent"
                                            CornerRadius="6"
                                            Background="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Root" Property="BorderBrush"
                                                    Value="{StaticResource AccentBrush}"/>
                                            <Setter TargetName="Root" Property="Background"
                                                    Value="#18E94560"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected"  Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Root" Property="Background"
                                                    Value="#09000000"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

            </ListBox>
        </ScrollViewer>

    </DockPanel>
</UserControl>
