<UserControl x:Class="projekt2wpf.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#FAFAFA">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">

            <TextBlock Text="📚"
                       FontSize="56" HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <TextBlock Text="Libraria"
                       FontFamily="Segoe Script" FontSize="32"
                       Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>

            <TextBlock Text="Your personal book collection manager"
                       FontSize="13" Foreground="#888888"
                       HorizontalAlignment="Center" Margin="0,0,0,40"
                       TextAlignment="Center"/>

            <Button Content="📁  Create New Repository"
                    Command="{Binding CreateRepositoryCommand}"
                    Height="44" FontSize="14" Margin="0,0,0,12"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White" BorderBrush="{StaticResource PrimaryBrush}"
                    Cursor="Hand"/>

            <Button Content="🗂  Open Existing Repository"
                    Command="{Binding OpenRepositoryCommand}"
                    Height="44" FontSize="14"
                    Background="White" Foreground="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2"
                    Cursor="Hand"/>

        </StackPanel>
    </Grid>
</UserControl>
