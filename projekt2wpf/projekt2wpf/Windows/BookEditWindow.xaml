<Window x:Class="projekt2wpf.BookEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:projekt2wpf"
        Title="Edit Book"
        Width="580" Height="660"
        MinWidth="520" MinHeight="560"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <DockPanel>

        <Border DockPanel.Dock="Bottom"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Background="White" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Width="90" Height="34"
                        Margin="0,0,10,0"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White" BorderBrush="{StaticResource AccentBrush}"
                        Cursor="Hand" FontSize="13"/>
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Width="90" Height="34"
                        Background="White" Foreground="#333"
                        BorderBrush="#CCCCCC"
                        Cursor="Hand" FontSize="13"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Cover" FontWeight="SemiBold" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <Border Width="120" Height="160"
                            Background="#E4E4E4" CornerRadius="4"
                            ClipToBounds="True" Margin="0,0,0,8">
                        <Grid>
                            <TextBlock Text="No Cover"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#999" FontSize="12"/>
                            <Image Source="{Binding CoverImage, Converter={StaticResource ByteToImageConverter}}"
                                   Stretch="UniformToFill"/>
                        </Grid>
                    </Border>
                    <Button Content="Browse Image..."
                            Command="{Binding BrowseCoverCommand}"
                            Padding="0,6" FontSize="11" Cursor="Hand"/>
                </StackPanel>

                <StackPanel Grid.Column="1">

                    <TextBlock Text="Title *" FontWeight="SemiBold" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,5" Margin="0,0,0,14" FontSize="13"/>

                    <TextBlock Text="Author" FontWeight="SemiBold" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,5" Margin="0,0,0,14" FontSize="13"/>

                    <TextBlock Text="Genre" FontWeight="SemiBold" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Genre, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,5" Margin="0,0,0,14" FontSize="13"/>

                    <TextBlock Text="Status" FontWeight="SemiBold" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding StatusStr}"
                              Height="30" Margin="0,0,0,14" FontSize="13"/>

                    <TextBlock Text="Rating" FontWeight="SemiBold" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <local:RatingControl Value="{Binding Rating, Mode=TwoWay}"
                                         IsReadOnly="False" StarSize="22"
                                         Margin="0,0,0,14"/>

                    <TextBlock Text="Total Pages" FontWeight="SemiBold" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding TotalPagesText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,5" Margin="0,0,0,14" FontSize="13"/>

                    <TextBlock Text="Book File (Markdown)" FontWeight="SemiBold" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding BookFileDisplay}"
                                   VerticalAlignment="Center" FontSize="12"
                                   Foreground="#666" TextTrimming="CharacterEllipsis"
                                   Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Browse..."
                                Command="{Binding BrowseBookCommand}"
                                Padding="10,6" FontSize="11" Cursor="Hand"/>
                    </Grid>

                    <TextBlock Text="Description" FontWeight="SemiBold" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,5" Margin="0,0,0,14" FontSize="13"
                             Height="70" AcceptsReturn="True"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Tags" FontWeight="SemiBold" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <local:TagControl Tags="{Binding Tags}"
                                      IsEditable="True"
                                      RemoveTagCommand="{Binding RemoveTagCommand}"
                                      Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding NewTag, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,5" Margin="0,0,8,0" FontSize="13">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddTagCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Content="+ Add Tag"
                                Command="{Binding AddTagCommand}"
                                Padding="10,6" FontSize="11" Cursor="Hand"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="White" BorderBrush="{StaticResource PrimaryBrush}"/>
                    </Grid>

                </StackPanel>
            </Grid>
        </ScrollViewer>

    </DockPanel>
</Window>
